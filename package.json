{
  "name": "temp-vite",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "partytown copylib public/~partytown && vite",
    "build": "partytown copylib public/~partytown && tsc -b && vite build",
    "analyze": "partytown copylib public/~partytown && vite build --mode analyze",
    "size": "node scripts/check-size.js",
    "show-stats": "node scripts/open-stats.js",
    "scan": "react-scan",
    "dev:watch": "concurrently \"bun run dev\" \"bun run scan\"",
    "lint": "biome check .",
    "test": "vitest run",
    "test:live": "vitest",
    "test:ui": "vitest --ui",
    "preview": "vite preview",
    "doctor": "npx react-doctor@latest"
  },
  "dependencies": {
    "@builder.io/partytown": "^0.10.3",
    "@fontsource-variable/geist": "^5.2.9",
    "@preact/signals-react": "^3.10.2",
    "@t3-oss/env-core": "^0.13.11",
    "@tailwindcss/vite": "^4.3.1",
    "axios": "^1.18.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.20.0",
    "nuqs": "^2.8.9",
    "radix-ui": "^1.6.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-scan": "^0.5.7",
    "shadcn": "^4.11.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.1",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3",
    "zundo": "^2.3.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@rolldown/plugin-babel": "^0.2.3",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/ui": "^4.1.9",
    "babel-plugin-react-compiler": "^1.0.0",
    "concurrently": "^10.0.3",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "react-doctor": "^0.5.7",
    "rollup-plugin-visualizer": "^7.0.1",
    "typescript": "~6.0.2",
    "vite": "^8.0.12",
    "vitest": "^4.1.9",
    "zod-validation-error": "^4.0.0"
  },
  "overrides": {
    "zod-validation-error": "^4.0.0"
  },
  "resolutions": {
    "zod-validation-error": "^4.0.0"
  }
}
